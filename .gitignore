# Results: keep figures (.png) and small JSON provenance in git; drop the heavy
# regenerable pickles. NB: we deliberately do NOT blanket-ignore results/ — git
# cannot re-include a file once its parent directory has been ignored.

# Pickle files (anywhere) — regenerable EnKF trajectories, ~27 MB each, too big for git
*.pkl

# PDFs
*.pdf

# Console run logs and one-off binaries (kept on disk, not in git)
*.log
*.pptx

# Claude Code project file + personal local settings (e.g. auto-push-figures hook)
CLAUDE.md
.claude/settings.local.json

# Poster / one-off plotting scripts
plot_poster_*.py

# Superseded scripts + result folders — kept on disk for provenance, out of the
# published repo. The paper's pipeline (04_cross_validate -> the three
# results_multirun_* folders) does not depend on any of these.
/scripts/legacy/
/results/
/results_asn_alpha0.01/
/results_legacy/

# Original notebook (superseded by nsd_enkf/ + scripts/)
JPC_NSD_softsensing.ipynb

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints
