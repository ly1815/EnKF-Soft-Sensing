# Results folders — generated outputs (figures, trajectories, provenance JSON).
# All regenerable by re-running the scripts; not tracked in the code repo. Kept on disk.
/results*/

# Exception: ship the small calibration inputs the multi-seed scripts read
# (per-fold calibrated CVs + the α picks). Re-include the parent dirs level by
# level so git can descend to the two JSON types; everything else stays ignored.
!/results_single_sweep/
/results_single_sweep/*
!/results_single_sweep/picks.json
!/results_single_sweep/fold_*/
/results_single_sweep/fold_*/*
!/results_single_sweep/fold_*/cv/
/results_single_sweep/fold_*/cv/*
!/results_single_sweep/fold_*/cv/cv_final.json

# Pickle files (anywhere) — regenerable EnKF trajectories, ~27 MB each, too big for git
*.pkl

# PDFs
*.pdf

# Console run logs and one-off binaries (kept on disk, not in git)
*.log
*.pptx

# Claude Code project file + personal local settings (e.g. auto-push-figures hook)
CLAUDE.md
.claude/settings.local.json

# Poster / one-off plotting scripts
plot_poster_*.py

# Superseded scripts — kept on disk for provenance, out of the published repo.
/scripts/legacy/

# Original notebook (superseded by nsd_enkf/ + scripts/)
JPC_NSD_softsensing.ipynb

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

